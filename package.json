{
  "name": "stark",
  "version": "0.1.0",
  "description": "Stark — a native Mac control center for local AI work. Install once, connect your model, approve what matters, and let an AI operator work across files, browser, terminal, memory, skills, automations, and messaging.",
  "private": true,
  "author": "Stark Contributors",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "icon": "node scripts/render-icon.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack:mac": "electron-vite build && electron-builder --mac --universal",
    "release:mac": "electron-vite build && electron-builder --mac --universal --publish always"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.1.1",
    "@fontsource/geist-sans": "^5.1.1",
    "@fontsource/instrument-serif": "^5.1.1",
    "@tanstack/react-query": "^5.66.0",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
